<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.tliaswebmanagement.Mapper.EmployeeMapper">

    <insert id="EmployeeDataInsert" useGeneratedKeys="true" keyProperty="id">
        insert into employee(
            user_name,name,pass_word,gender,phone_number,job,department_id,salary,image,entry_date,create_time,update_time
        )
        values(
            #{userName},#{name},#{passWord},#{gender},#{phoneNumber},#{job},#{departmentId},#{salary},#{image},#{entryDate},#{createTime},#{updateTime}
        )
    </insert>

    <select id="queryByParameters" resultType="org.example.tliaswebmanagement.EntityClass.Employee">
        select
            em.id,user_name,em.name,gender,image,job,salary,entry_date,department_id,dp.name,dp.create_time,dp.update_time
        from
            employee em
                left join
            department dp
            on dp.id = em.department_id
        <where>
            <if test="gender != null and gender != ''">
                em.gender = #{gender}
            </if>
            <if test="name != null and name != ''">
                and em.name like concat('%','五','%')
            </if>
            <if test="beginTime != null and beginTime != ''">
                and em.create_time between #{beginTime} and #{endTime}
            </if>
        </where>
    </select>

</mapper>